model Model
	culture: pt-BR
	defaultPowerBIDataSourceVersion: powerBI_V3
	sourceQueryCulture: pt-BR
	dataAccessOptions
		legacyRedirects
		returnErrorValuesAsNull

/// Grupo de consultas para diagnóstico
queryGroup Paramentros

	annotation PBI_QueryGroupOrder = 0

queryGroup Funcoes

	annotation PBI_QueryGroupOrder = 1

queryGroup dimensoes

	annotation PBI_QueryGroupOrder = 2

queryGroup Fatos

	annotation PBI_QueryGroupOrder = 3

annotation __PBI_TimeIntelligenceEnabled = 0

annotation PBI_ProTooling = ["DevMode"]

annotation PBI_QueryOrder = ["data_inicial","base_transacoes","data_final","moedas","calendario","transacoes","getCotacoes","cotacoes"]

ref table moedas
ref table calendario
ref table transacoes
ref table cotacoes

ref cultureInfo pt-BR

